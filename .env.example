NODE_ENV=development
PORT=3000
# Host port mapping when 3000 is already taken on the machine (maps host→container)
# Example: APP_HOST_PORT=3010 keeps the app on 3000 inside Docker; Traefik still uses 3000.
APP_HOST_PORT=3000
APP_URL=http://localhost:3000
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=30m
COOKIE_SECURE=auto
# Set true behind Cloudflare Tunnel / reverse proxy (fixes playback token IP binding)
TRUST_PROXY=true

# Database — use DB_HOST=db for Docker Compose / Dokploy; 127.0.0.1 for local npm run dev
# MYSQL_* must match DB_* — MySQL only applies these on FIRST volume init (see README if access denied)
DB_HOST=db
DB_PORT=3306
DB_USER=video_app
DB_PASSWORD=video_app_password
DB_NAME=video_portal
MYSQL_ROOT_PASSWORD=root_password_change_me
UPLOAD_DIR=./media/uploads
HLS_DIR=./media/hls
# Max parallel FFmpeg jobs (keep at 1 on NUC to avoid CPU spikes after redeploy)
MAX_CONCURRENT_TRANSCODES=1
PLAYBACK_TOKEN_TTL_SECONDS=1200
PLAYBACK_TOKEN_GRACE_SECONDS=30
PROGRESS_SAVE_INTERVAL_SECONDS=15
PROGRESS_COMPLETE_RATIO=0.95
MAX_ACTIVE_SESSIONS=1
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
ALLOW_SIGNUP_DEFAULT=false
FFMPEG_BIN=ffmpeg
FFMPEG_HWACCEL=none
FFMPEG_VAAPI_DEVICE=/dev/dri/renderD128
ENABLE_1080P=false
