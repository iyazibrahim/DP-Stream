<%- include('../partials/head.ejs', { title: 'Sign Up', user: null, bodyClass: 'auth-screen' }) %>
<section class="login-panel card auth-card">
  <div class="auth-logo-wrap">
    <%- include('../partials/brand-logo.ejs', { logoHref: '/login' }) %>
  </div>
  <h1 class="login-title">Create account</h1>
  <p class="login-subtitle">Admin approval required before sign in</p>

  <% if (error) { %><p class="error login-error"><%= error %></p><% } %>
  <% if (success) { %><p class="success login-success"><%= success %></p><% } %>

  <% if (!signupEnabled) { %>
    <p class="meta-text">Registration is currently closed. Contact your administrator.</p>
    <p><a class="login-help-link" href="/login">Back to sign in</a></p>
  <% } else if (!success) { %>
    <form method="post" action="/auth/signup" class="form-grid login-form">
      <label class="sr-only" for="signup-email">Email address</label>
      <input id="signup-email" type="email" name="email" placeholder="Email address" autocomplete="email" required />

      <label class="sr-only" for="signup-password">Password</label>
      <input id="signup-password" type="password" name="password" placeholder="Password" minlength="10" autocomplete="new-password" required />

      <p class="meta-text">At least 10 characters with uppercase, lowercase, and a number.</p>
      <button type="submit" class="login-submit">Register</button>
    </form>
    <p class="login-footnote">Already have an account? <a class="login-help-link" href="/login">Sign in</a>.</p>
  <% } else { %>
    <p><a class="login-help-link" href="/login">Back to sign in</a></p>
  <% } %>
  <button type="button" class="icon-btn theme-toggle theme-toggle--auth" data-theme-toggle aria-label="Switch theme" aria-pressed="false">
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" hidden><circle cx="12" cy="12" r="4"/></svg>
  </button>
</section>
<%- include('../partials/foot.ejs') %>
