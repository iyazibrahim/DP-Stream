<%- include('../partials/head.ejs', { title: 'Reset Password', user, bodyClass: 'auth-screen' }) %>
<section class="login-panel card auth-card">
  <div class="auth-logo-wrap">
    <%- include('../partials/brand-logo.ejs', { logoHref: '/videos' }) %>
  </div>
  <h1 class="login-title">Reset password</h1>
  <p class="login-subtitle">Set a new password to continue</p>
  <p class="meta-text">At least 10 characters with uppercase, lowercase, and a number.</p>

  <% if (error) { %><p class="error login-error"><%= error %></p><% } %>
  <% if (success) { %><p class="success"><%= success %></p><% } %>

  <form method="post" action="/auth/reset-password" class="form-grid login-form">
    <label class="sr-only" for="reset-password-input">New Password</label>
    <input id="reset-password-input" type="password" name="newPassword" placeholder="New Password" minlength="10" autocomplete="new-password" required />
    <button type="submit" class="login-submit">Update password</button>
  </form>
  <button type="button" class="theme-toggle theme-toggle--auth" data-theme-toggle aria-label="Switch theme">Light</button>
</section>
<%- include('../partials/foot.ejs') %>
