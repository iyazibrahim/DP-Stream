            <% } %>
          </div>
          <p class="meta-text">Job: <%= v.job_status || '-' %> <% if (v.job_attempts) { %>(attempts: <%= v.job_attempts %>)<% } %></p>
          <% if (v.repair_message) { %>
            <p class="<%= v.repair_state === 'source_missing' ? 'error' : 'meta-text' %>"><%= v.repair_message %></p>
